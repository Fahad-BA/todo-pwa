---
import Layout from '../layouts/Layout.astro';
import { initDatabase } from '../database.js';

// PostgreSQL version - stores data locally or remotely
// Initialize database on server startup
if (import.meta.env.SSR) {
  initDatabase();
}
---
<Layout title="مهامي - Task Manager" description="تطبيق إدارة المهام PWA">
  <div class="max-w-2xl mx-auto">
    <!-- Add Task Form -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-6 mb-6">
      <form id="addTaskForm" class="space-y-4">
        <div>
          <label for="taskInput" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
            مهمة جديدة
          </label>
          <div class="flex space-x-reverse space-x-3">
            <input
              type="text"
              id="taskInput"
              placeholder="أكتب مهمة جديدة..."
              class="flex-1 px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent bg-white dark:bg-gray-700 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400"
              dir="rtl"
              autocomplete="off"
            />
            <button
              type="submit"
              class="px-6 py-2 bg-green-500 hover:bg-green-600 text-white rounded-lg transition-colors font-medium focus:ring-2 focus:ring-green-500 focus:ring-offset-2 dark:focus:ring-offset-gray-800"
            >
              إضافة
            </button>
          </div>
        </div>
      </form>
    </div>

    <!-- Manual Refresh Button -->
    <div class="flex justify-end mb-4">
      <button
        id="refreshButton"
        onclick="manualRefresh()"
        class="flex items-center space-x-reverse space-x-2 px-4 py-2 bg-blue-500 hover:bg-blue-600 text-white rounded-lg transition-colors text-sm"
        title="تحديث المهام يدويًا"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M4 2a1 1 0 011 1v2.101a7.002 7.002 0 0111.601 2.566 1 1 0 11-1.885.666A5.002 5.002 0 005.999 7H9a1 1 0 010 2H4a1 1 0 01-1-1V3a1 1 0 011-1zm.008 9.057a1 1 0 011.276.61A5.002 5.002 0 0014.001 13H11a1 1 0 110-2h5a1 1 0 011 1v5a1 1 0 11-2 0v-2.101a7.002 7.002 0 01-11.601-2.566 1 1 0 01.61-1.276z" clip-rule="evenodd"></path>
        </svg>
        <span>تحديث</span>
      </button>
    </div>

    <!-- Tasks Display -->
    <div id="tasksContainer">
      <div class="text-center py-8">
        <div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-green-500"></div>
        <p class="mt-2 text-gray-600 dark:text-gray-400">يتم تحميل المهام...</p>
      </div>
    </div>

    <!-- Connection Status -->
    <div id="connectionStatus" class="hidden fixed top-4 right-4 bg-blue-500 text-white px-4 py-2 rounded-lg shadow-lg z-50">
      <div class="flex items-center">
        <svg class="w-5 h-5 ml-2" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M12.316 3.051a1 1 0 01.633 1.265l-4 12a1 1 0 11-1.898-.632l4-12a1 1 0 011.265-.633zM5.707 6.707a1 1 0 010-1.414l8-8a1 1 0 111.414 1.414l-8 8a1 1 0 01-1.414 0zm8.586 0a1 1 0 011.414 0l4 4a1 1 0 11-1.414 1.414l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"></path>
        </svg>
        متصل بـ PostgreSQL
      </div>
    </div>

    <!-- Edit Modal -->
    <div id="editModal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
      <div class="bg-white dark:bg-gray-800 rounded-lg p-6 w-full max-w-md mx-4">
        <h3 class="text-lg font-semibold text-gray-800 dark:text-white mb-4">تعديل المهمة</h3>
        <form id="editTaskForm">
          <input
            type="text"
            id="editTaskInput"
            class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent bg-white dark:bg-gray-700 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400 mb-4"
            dir="rtl"
          />
          <div class="flex space-x-reverse space-x-3 justify-end">
            <button
              type="button"
              onclick="closeEditModal()"
              class="px-4 py-2 text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg transition-colors"
            >
              إلغاء
            </button>
            <button
              type="submit"
              class="px-4 py-2 bg-green-500 hover:bg-green-600 text-white rounded-lg transition-colors"
            >
              حفظ
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script>
    // Define global functions immediately to ensure they're available when DOM is ready
    window.toggleTask = async (taskId) => {
      console.log('toggleTask called with ID:', taskId);
      
      try {
        const task = window.tasks ? window.tasks.find(t => t.id === taskId) : null;
        if (!task) {
          console.error('Task not found:', taskId);
          // Fallback: fetch the task directly
          const response = await fetch(`/api/tasks/${taskId}`);
          if (!response.ok) {
            throw new Error('Task not found');
          }
          const taskData = await response.json();
          
          const updateResponse = await fetch(`/api/tasks/${taskId}`, {
            method: 'PUT',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({
              completed: !taskData.completed
            }),
          });
          
          if (!updateResponse.ok) {
            throw new Error('Failed to update task');
          }
          
          // Reload tasks
          if (window.loadTasks) {
            await window.loadTasks();
          }
          return;
        }

        const response = await fetch(`/api/tasks/${taskId}`, {
          method: 'PUT',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            completed: !task.completed
          }),
        });
        
        if (!response.ok) {
          throw new Error('Failed to update task');
        }
        
        // Reload tasks
        if (window.loadTasks) {
          await window.loadTasks();
        }
        
      } catch (error) {
        console.error('Error toggling task:', error);
        alert('فشل تحديث المهمة: ' + error.message);
      }
    };

    window.deleteTask = async (taskId) => {
      if (!confirm('هل أنت متأكد من حذف هذه المهمة؟')) return;
      
      try {
        // Validate and sanitize taskId
        if (!taskId && taskId !== 0) {
          throw new Error('معرّف المهمة غير صالح');
        }
        
        // Ensure taskId is a string and properly sanitized
        const cleanTaskId = String(taskId).trim();
        
        // Additional validation: ensure cleanTaskId is not empty after trimming
        if (!cleanTaskId) {
          throw new Error('معرّف المهمة غير صالح');
        }
        
        // Validate that taskId is a number (PostgreSQL SERIAL)
        if (!/^\d+$/.test(cleanTaskId)) {
          throw new Error('معرّف المهمة يجب أن يكون رقماً');
        }
        
        console.log('Attempting to delete task:', cleanTaskId, 'Type:', typeof cleanTaskId);
        
        // Construct URL with proper encoding
        const url = `/api/tasks/${encodeURIComponent(cleanTaskId)}`;
        console.log('Delete URL:', url);
        
        const response = await fetch(url, {
          method: 'DELETE',
          headers: {
            'Content-Type': 'application/json',
          },
        });
        
        console.log('Delete response status:', response.status);
        console.log('Delete response headers:', response.headers);
        
        if (!response.ok) {
          const errorData = await response.json().catch(() => ({}));
          console.log('Error response data:', errorData);
          throw new Error(errorData.error || `فشل حذف المهمة (رمز الحالة: ${response.status})`);
        }
        
        const result = await response.json();
        console.log('Delete result:', result);
        
        // Reload tasks
        if (window.loadTasks) {
          await window.loadTasks();
        }
        
      } catch (error) {
        console.error('Error deleting task:', error);
        console.error('Error stack:', error.stack);
        alert('فشل حذف المهمة: ' + error.message);
      }
    };

    window.editTask = (taskId) => {
      const task = window.tasks ? window.tasks.find(t => t.id === taskId) : null;
      if (!task) {
        console.error('Task not found:', taskId);
        return;
      }

      window.currentEditTaskId = taskId;
      const editTaskInput = document.getElementById('editTaskInput');
      const editModal = document.getElementById('editModal');
      
      if (editTaskInput && editModal) {
        editTaskInput.value = task.text;
        editModal.classList.remove('hidden');
      }
    };

    window.closeEditModal = () => {
      const editModal = document.getElementById('editModal');
      if (editModal) {
        editModal.classList.add('hidden');
      }
      window.currentEditTaskId = null;
    };

    window.manualRefresh = async () => {
      const refreshBtn = document.getElementById('refreshButton');
      if (refreshBtn) {
        refreshBtn.disabled = true;
        refreshBtn.innerHTML = '<svg class="w-4 h-4 animate-spin" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4 2a1 1 0 011 1v2.101a7.002 7.002 0 0111.601 2.566 1 1 0 11-1.885.666A5.002 5.002 0 005.999 7H9a1 1 0 010 2H4a1 1 0 01-1-1V3a1 1 0 011-1zm.008 9.057a1 1 0 011.276.61A5.002 5.002 0 0014.001 13H11a1 1 0 110-2h5a1 1 0 011 1v5a1 1 0 11-2 0v-2.101a7.002 7.002 0 01-11.601-2.566 1 1 0 01.61-1.276z" clip-rule="evenodd"></path></svg><span>جاري التحديث...</span>';
      }
      
      if (window.loadTasks) {
        await window.loadTasks();
      }
      
      if (refreshBtn) {
        setTimeout(() => {
          refreshBtn.disabled = false;
          refreshBtn.innerHTML = '<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4 2a1 1 0 011 1v2.101a7.002 7.002 0 0111.601 2.566 1 1 0 11-1.885.666A5.002 5.002 0 005.999 7H9a1 1 0 010 2H4a1 1 0 01-1-1V3a1 1 0 011-1zm.008 9.057a1 1 0 011.276.61A5.002 5.002 0 0014.001 13H11a1 1 0 110-2h5a1 1 0 011 1v5a1 1 0 11-2 0v-2.101a7.002 7.002 0 01-11.601-2.566 1 1 0 01.61-1.276z" clip-rule="evenodd"></path></svg><span>تحديث</span>';
        }, 1000);
      }
    };

    // Initialize global variables
    window.tasks = [];
    window.currentEditTaskId = null;
    window.refreshInterval = null;
  </script>

  <script>
    // Event delegation for task actions
    document.addEventListener('click', function(event) {
      // Check if the clicked element has a data-action attribute
      const action = event.target.closest('[data-action]');
      if (!action) return;
      
      const taskId = action.getAttribute('data-task-id');
      const actionType = action.getAttribute('data-action');
      
      console.log('Action clicked:', actionType, 'Task ID:', taskId);
      
      switch (actionType) {
        case 'toggle':
          if (window.toggleTask) {
            window.toggleTask(taskId);
          } else {
            console.error('toggleTask function not found');
          }
          break;
          
        case 'edit':
          if (window.editTask) {
            window.editTask(taskId);
          } else {
            console.error('editTask function not found');
          }
          break;
          
        case 'delete':
          if (window.deleteTask) {
            window.deleteTask(taskId);
          } else {
            console.error('deleteTask function not found');
          }
          break;
      }
    });

    // Direct edit functionality
    document.addEventListener('click', function(event) {
      // Check if clicked on a task text
      const taskText = event.target.closest('.task-text[data-editable="true"]');
      if (!taskText) return;
      
      const taskId = taskText.getAttribute('data-task-id');
      if (!taskId) return;
      
      // Make the task text editable
      taskText.contentEditable = true;
      taskText.focus();
      
      // Select all text
      const range = document.createRange();
      range.selectNodeContents(taskText);
      const selection = window.getSelection();
      selection.removeAllRanges();
      selection.addRange(range);
      
      // Store original text
      const originalText = taskText.textContent;
      
      // Handle blur and enter key
      function finishEdit() {
        taskText.contentEditable = false;
        const newText = taskText.textContent.trim();
        
        if (newText && newText !== originalText) {
          // Update the task
          fetch(`/api/tasks/${taskId}`, {
            method: 'PUT',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({
              text: newText
            }),
          })
          .then(response => {
            if (!response.ok) {
              throw new Error('Failed to update task');
            }
            return response.json();
          })
          .then(() => {
            if (window.loadTasks) {
              window.loadTasks();
            }
          })
          .catch(error => {
            console.error('Error updating task:', error);
            taskText.textContent = originalText; // Revert on error
          });
        } else {
          taskText.textContent = originalText; // Revert if empty or unchanged
        }
        
        // Remove event listeners
        taskText.removeEventListener('blur', finishEdit);
        taskText.removeEventListener('keydown', handleKeyDown);
      }
      
      function handleKeyDown(event) {
        if (event.key === 'Enter') {
          event.preventDefault();
          finishEdit();
        } else if (event.key === 'Escape') {
          taskText.textContent = originalText;
          finishEdit();
        }
      }
      
      taskText.addEventListener('blur', finishEdit);
      taskText.addEventListener('keydown', handleKeyDown);
    });

    // Also add event delegation for the manual refresh button
    document.addEventListener('click', function(event) {
      if (event.target.closest('#refreshButton')) {
        event.preventDefault();
        if (window.manualRefresh) {
          window.manualRefresh();
        } else {
          console.error('manualRefresh function not found');
        }
      }
    });

    // Event delegation for form submissions
    document.addEventListener('submit', function(event) {
      // Handle edit task form
      if (event.target.id === 'editTaskForm') {
        event.preventDefault();
        
        const editTaskInput = document.getElementById('editTaskInput');
        const newText = editTaskInput.value.trim();
        
        if (!newText || !window.currentEditTaskId) {
          console.log('No text or current edit task ID');
          return;
        }

        console.log('Editing task:', window.currentEditTaskId, 'New text:', newText);
        
        // Use the global functions
        if (window.pauseAutoRefresh) window.pauseAutoRefresh();
        
        fetch(`/api/tasks/${window.currentEditTaskId}`, {
          method: 'PUT',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            text: newText
          }),
        })
        .then(response => {
          if (!response.ok) {
            throw new Error('Failed to update task');
          }
          return response.json();
        })
        .then(() => {
          if (window.closeEditModal) window.closeEditModal();
          if (window.loadTasks) return window.loadTasks();
        })
        .then(() => {
          if (window.resumeAutoRefresh) window.resumeAutoRefresh();
        })
        .catch(error => {
          console.error('Error updating task:', error);
          alert('فشل تحديث المهمة: ' + error.message);
          if (window.resumeAutoRefresh) window.resumeAutoRefresh();
        });
      }
      
      // Handle add task form
      if (event.target.id === 'addTaskForm') {
        event.preventDefault();
        
        const taskInput = document.getElementById('taskInput');
        const text = taskInput.value.trim();
        
        if (!text) return;
        
        console.log('Adding new task:', text);
        
        if (window.pauseAutoRefresh) window.pauseAutoRefresh();
        
        fetch('/api/tasks', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            text: text,
            userId: 'default-user'
          }),
        })
        .then(response => {
          if (!response.ok) {
            throw new Error('Failed to create task');
          }
          taskInput.value = '';
          if (window.loadTasks) return window.loadTasks();
        })
        .then(() => {
          if (window.resumeAutoRefresh) window.resumeAutoRefresh();
        })
        .catch(error => {
          console.error('Error adding task:', error);
          alert('فشل إضافة المهمة: ' + error.message);
          if (window.resumeAutoRefresh) window.resumeAutoRefresh();
        });
      }
    });
  </script>

  <script type="module">
    // Module script - will execute after the global functions are defined
    let tasks = [];
    let currentEditTaskId = null;
    let refreshInterval = null;

    // Make variables accessible globally
    window.tasks = tasks;
    window.currentEditTaskId = currentEditTaskId;
    window.refreshInterval = refreshInterval;

    // DOM elements
    const addTaskForm = document.getElementById('addTaskForm');
    const taskInput = document.getElementById('taskInput');
    const tasksContainer = document.getElementById('tasksContainer');
    const editModal = document.getElementById('editModal');
    const editTaskForm = document.getElementById('editTaskForm');
    const editTaskInput = document.getElementById('editTaskInput');
    const connectionStatus = document.getElementById('connectionStatus');

    // Show connection status (disabled for less intrusive UX)
    function showConnectionStatus() {
      // Commented out to avoid showing connection status on every refresh
      // connectionStatus.classList.remove('hidden');
      // setTimeout(() => {
      //   connectionStatus.classList.add('hidden');
      // }, 3000);
    }

    // Load tasks from PostgreSQL API
    window.loadTasks = async function loadTasks() {
      // Skip loading if user is currently interacting
      if (isUserInteracting) {
        console.log('Skipping task load - user is interacting');
        return;
      }

      try {
        const response = await fetch('/api/tasks?userId=default-user');
        if (!response.ok) {
          throw new Error('Failed to fetch tasks');
        }
        tasks = await response.json();
        renderTasks();
        showConnectionStatus();
      } catch (error) {
        console.error('Error loading tasks:', error);
        showError('فشل تحميل المهام من PostgreSQL');
      }
    }

    // Auto-refresh tasks every 30 seconds (reduced frequency to avoid conflicts)
    function startAutoRefresh() {
      if (refreshInterval) {
        clearInterval(refreshInterval);
      }
      refreshInterval = setInterval(loadTasks, 30000); // Changed to 30 seconds
    }

    // Pause auto-refresh during user interactions
    let isUserInteracting = false;
    let refreshTimeout = null;

    function pauseAutoRefresh() {
      isUserInteracting = true;
      if (refreshTimeout) {
        clearTimeout(refreshTimeout);
      }
    }

    function resumeAutoRefresh() {
      isUserInteracting = false;
      // Resume auto-refresh after 10 seconds of no interaction
      refreshTimeout = setTimeout(() => {
        if (refreshInterval && !isUserInteracting) {
          loadTasks();
        }
      }, 10000);
    }

    // Render tasks
    function renderTasks() {
      if (tasks.length === 0) {
        tasksContainer.innerHTML = '<div class="text-center py-12"><svg class="w-16 h-16 mx-auto text-gray-300 dark:text-gray-600 mb-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M3 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm0 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm0 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm0 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1z" clip-rule="evenodd"></path></svg><h3 class="text-lg font-medium text-gray-500 dark:text-gray-400 mb-2">ما في مهام!</h3><p class="text-gray-400 dark:text-gray-500">أضف مهمة جديدة باستخدام الحقل أدناه</p></div>';
        return;
      }

      const incompleteTasks = tasks.filter(task => !task.completed);
      const completedTasks = tasks.filter(task => task.completed);

      let html = '';

      if (incompleteTasks.length > 0) {
        html += '<div><h2 class="text-lg font-semibold text-gray-800 dark:text-white mb-3 flex items-center"><svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zM4 8h12v8H4V8z" clip-rule="evenodd"></path></svg>المهام النشطة (' + incompleteTasks.length + ')</h2><div class="space-y-3">' + incompleteTasks.map(task => createTaskHTML(task)).join('') + '</div></div>';
      }

      if (completedTasks.length > 0) {
        html += '<div><h2 class="text-lg font-semibold text-gray-500 dark:text-gray-400 mb-3 flex items-center"><svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>المهام المكتملة (' + completedTasks.length + ')</h2><div class="space-y-3">' + completedTasks.map(task => createTaskHTML(task)).join('') + '</div></div>';
      }

      tasksContainer.innerHTML = html;
    }

    // Create task HTML
    function createTaskHTML(task) {
      // Validate task object
      if (!task || typeof task.id === 'undefined') {
        console.error('Invalid task object:', task);
        return '';
      }
      
      // Ensure task ID is a string for HTML attributes
      const taskId = String(task.id);
      
      // Use updated_at if task is completed, otherwise use created_at
      const date = new Date(task.completed ? (task.updated_at || task.created_at) : task.created_at);
      
      // Force Gregorian calendar by explicitly using ar-EG locale
      const formattedDate = date.toLocaleDateString('ar-EG', {
        year: 'numeric',
        month: 'short',
        day: 'numeric',
        hour: '2-digit',
        minute: '2-digit',
        calendar: 'gregory',
        timeZone: 'Asia/Riyadh'
      });

      const completedClass = task.completed ? 'opacity-75' : '';
      const buttonClass = task.completed ? 'bg-green-500 border-green-500 text-white' : 'border-gray-300 dark:border-gray-600 hover:border-green-500';
      const textClass = task.completed ? 'line-through text-gray-500 dark:text-gray-400' : 'text-gray-800 dark:text-white';
      const checkmark = task.completed ? '<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>' : '';

      return '<div class="task-item group bg-white dark:bg-gray-800 rounded-lg shadow-sm hover:shadow-md transition-all duration-200 mb-3 ' + completedClass + '"><div class="flex items-center justify-between p-4"><div class="flex items-center space-x-reverse space-x-3 flex-1"><button data-task-id="' + taskId + '" data-action="toggle" class="task-checkbox w-6 h-6 rounded-full border-2 flex items-center justify-center transition-colors ' + buttonClass + '" aria-label="' + (task.completed ? 'إلغاء الإكمال' : 'إتمام المهمة') + '">' + checkmark + '</button><div class="flex-1"><p class="task-text ' + textClass + '" data-task-id="' + taskId + '" contenteditable="false" data-editable="true">' + task.text + '</p><p class="text-xs text-gray-400 dark:text-gray-500 mt-1">' + formattedDate + '</p></div></div><div class="flex items-center space-x-reverse space-x-2 opacity-0 group-hover:opacity-100 transition-opacity duration-200"><button data-task-id="' + taskId + '" data-action="edit" class="p-2 text-blue-500 hover:bg-blue-50 dark:hover:bg-blue-900/20 rounded-lg transition-colors" title="تعديل المهمة"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z"></path></svg></button><button data-task-id="' + taskId + '" data-action="delete" class="p-2 text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-lg transition-colors" title="حذف المهمة"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd"></path></svg></button></div></div></div></div>';
    }

    // Add task form - now handled by event delegation above

    // Global functions are now defined in the regular script tag above
    // This prevents timing issues with onclick handlers

    // Edit task form - will be handled by event delegation

    // Show error message
    function showError(message) {
      const errorDiv = document.createElement('div');
      errorDiv.className = 'fixed top-4 right-4 bg-red-500 text-white px-4 py-2 rounded-lg shadow-lg z-50';
      errorDiv.textContent = message;
      document.body.appendChild(errorDiv);
      
      setTimeout(() => {
        errorDiv.remove();
      }, 3000);
    }

    // Manual refresh function is now defined in the global script above

    // Initialize tasks and start auto-refresh
    loadTasks();
    startAutoRefresh();

    // Cleanup on page unload
    window.addEventListener('beforeunload', () => {
      if (refreshInterval) {
        clearInterval(refreshInterval);
      }
    });
  </script>

  <script type="module">
    // Dark mode and PWA functionality
    const html = document.documentElement;
    const refreshButton = document.getElementById('refreshButton');
    const savedTheme = localStorage.getItem('theme');
    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;

    // Apply saved theme or system preference
    if (savedTheme === 'dark' || (!savedTheme && prefersDark)) {
      html.classList.add('dark');
    }

    // Dark mode toggle
    if (refreshButton) {
      refreshButton.addEventListener('click', () => {
        html.classList.toggle('dark');
        const isDark = html.classList.contains('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
      });
    }

    // Service Worker registration
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/sw.js').then(registration => {
          console.log('ServiceWorker registration successful with scope: ', registration.scope);
        }).catch(error => {
          console.log('ServiceWorker registration failed: ', error);
        });
      });
    }

    // PWA install prompt
    let deferredPrompt;
    window.addEventListener('beforeinstallprompt', (e) => {
      e.preventDefault();
      deferredPrompt = e;
    });

    window.addEventListener('appinstalled', () => {
      console.log('PWA was installed');
    });
  </script>
</Layout>
