---
import Layout from '../layouts/Layout.astro';
import TaskForm from '../components/TaskForm.astro';
import TaskStats from '../components/TaskStats.astro';
import TaskModal from '../components/TaskModal.astro';
import ToastNotifications from '../components/ToastNotifications.astro';
import ConnectionStatus from '../components/ConnectionStatus.astro';
---
<Layout title="TaskFlow - Smart Task Manager" description="Modern task management PWA application">
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-6">
    <!-- Add Task Form -->
    <TaskForm />
    
    <!-- Quick Stats -->
    <TaskStats />
    
    <!-- Tasks Display -->
    <div id="tasksContainer" class="space-y-4">
      <!-- Loading state will be shown here initially -->
      <div class="card p-8 text-center animate-fade-in">
        <div class="loading-pulse">
          <svg class="w-12 h-12 mx-auto text-primary-500 mb-4 animate-spin-slow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
          </svg>
        </div>
        <p class="text-lg font-medium text-gray-600 dark:text-gray-400">Loading your tasks...</p>
        <p class="text-sm text-gray-400 dark:text-gray-500 mt-1">Just a moment please</p>
      </div>
    </div>
  </div>

  <!-- Toast Notifications -->
  <ToastNotifications />
  
  <!-- Connection Status -->
  <ConnectionStatus />
  
  <!-- Edit Modal -->
  <TaskModal />

  <!-- Core Task Management Script -->
  <script type="module" src="/src/scripts/task-manager.js"></script>
  
  <!-- Event Handlers Script -->
  <script type="module" src="/src/scripts/event-handlers.js"></script>
  
  <!-- PWA Setup Script -->
  <script type="module" src="/src/scripts/pwa-setup.js"></script>
  
  <!-- Initialize tasks on page load -->
  <script type="module">
    // Initialize tasks when DOM is ready
    document.addEventListener('DOMContentLoaded', () => {
      console.log('Initializing tasks...');
      if (window.taskManager) {
        window.taskManager.loadTasks().then(() => {
          console.log('Tasks loaded successfully');
        }).catch(error => {
          console.error('Error loading tasks:', error);
        });
      } else {
        console.error('TaskManager not found');
      }
    });
  </script>
</Layout>