---
interface Props {
  task: {
    id: string;
    text: string;
    completed: boolean;
    createdAt: any;
  };
  onToggleComplete: (id: string) => void;
  onDelete: (id: string) => void;
  onEdit: (id: string, newText: string) => void;
}

const { task, onToggleComplete, onDelete, onEdit } = Astro.props;
---
<div class={`task-item group bg-white dark:bg-gray-800 rounded-lg shadow-sm hover:shadow-md transition-all duration-200 mb-3 ${task.completed ? 'opacity-75' : ''}`}>
  <div class="flex items-center justify-between p-4">
    <div class="flex items-center space-x-reverse space-x-3 flex-1">
      <button
        onclick={`toggleTask('${task.id}')`}
        class={`w-6 h-6 rounded-full border-2 flex items-center justify-center transition-colors ${
          task.completed 
            ? 'bg-green-500 border-green-500 text-white' 
            : 'border-gray-300 dark:border-gray-600 hover:border-green-500'
        }`}
        aria-label={task.completed ? 'إلغاء الإكمال' : 'إتمام المهمة'}
      >
        {task.completed && (
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
          </svg>
        )}
      </button>
      
      <div class="flex-1">
        <p 
          class={`task-text ${task.completed ? 'line-through text-gray-500 dark:text-gray-400' : 'text-gray-800 dark:text-white'}`}
          data-task-id={task.id}
        >
          {task.text}
        </p>
        <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">
          {new Date(task.createdAt?.toDate?.() || task.createdAt).toLocaleDateString('ar-SA', {
            year: 'numeric',
            month: 'short',
            day: 'numeric',
            hour: '2-digit',
            minute: '2-digit'
          })}
        </p>
      </div>
    </div>
    
    <div class="flex items-center space-x-reverse space-x-2 opacity-0 group-hover:opacity-100 transition-opacity duration-200">
      <button
        onclick={`editTask('${task.id}')`}
        class="p-2 text-blue-500 hover:bg-blue-50 dark:hover:bg-blue-900/20 rounded-lg transition-colors"
        title="تعديل المهمة"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
          <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z"></path>
        </svg>
      </button>
      
      <button
        onclick={`deleteTask('${task.id}')`}
        class="p-2 text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-lg transition-colors"
        title="حذف المهمة"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd"></path>
        </svg>
      </button>
    </div>
  </div>
</div>

<script>
  function toggleTask(taskId) {
    const event = new CustomEvent('toggleTask', { detail: { taskId } });
    document.dispatchEvent(event);
  }

  function deleteTask(taskId) {
    if (confirm('هل أنت متأكد من حذف هذه المهمة؟')) {
      const event = new CustomEvent('deleteTask', { detail: { taskId } });
      document.dispatchEvent(event);
    }
  }

  function editTask(taskId) {
    const event = new CustomEvent('editTask', { detail: { taskId } });
    document.dispatchEvent(event);
  }
</script>