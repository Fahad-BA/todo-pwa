---
import TaskItem from './TaskItem.astro';

interface Props {
  tasks: Array<{
    id: string;
    text: string;
    completed: boolean;
    createdAt: any;
  }>;
  onToggleComplete: (id: string) => void;
  onDelete: (id: string) => void;
  onEdit: (id: string, newText: string) => void;
}

const { tasks, onToggleComplete, onDelete, onEdit } = Astro.props;

// Separate completed and incomplete tasks
const incompleteTasks = tasks.filter(task => !task.completed);
const completedTasks = tasks.filter(task => task.completed);
---
<div class="space-y-4">
  <!-- Incomplete Tasks -->
  {incompleteTasks.length > 0 && (
    <div>
      <h2 class="text-lg font-semibold text-gray-800 dark:text-white mb-3 flex items-center">
        <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zM4 8h12v8H4V8z" clip-rule="evenodd"></path>
        </svg>
        Active Tasks ({incompleteTasks.length})
      </h2>
      <div class="space-y-3">
        {incompleteTasks.map((task) => (
          <TaskItem 
            task={task}
            onToggleComplete={onToggleComplete}
            onDelete={onDelete}
            onEdit={onEdit}
          />
        ))}
      </div>
    </div>
  )}

  <!-- Completed Tasks -->
  {completedTasks.length > 0 && (
    <div>
      <h2 class="text-lg font-semibold text-gray-500 dark:text-gray-400 mb-3 flex items-center">
        <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
        </svg>
        Completed Tasks ({completedTasks.length})
      </h2>
      <div class="space-y-3">
        {completedTasks.map((task) => (
          <TaskItem 
            task={task}
            onToggleComplete={onToggleComplete}
            onDelete={onDelete}
            onEdit={onEdit}
          />
        ))}
      </div>
    </div>
  )}

  <!-- Empty State -->
  {tasks.length === 0 && (
    <div class="text-center py-12">
      <svg class="w-16 h-16 mx-auto text-gray-300 dark:text-gray-600 mb-4" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M3 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm0 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm0 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm0 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1z" clip-rule="evenodd"></path>
      </svg>
      <h3 class="text-lg font-medium text-gray-500 dark:text-gray-400 mb-2">No tasks yet!</h3>
      <p class="text-gray-400 dark:text-gray-500">Add a new task using the field above</p>
    </div>
  )}
</div>